{
  "identifier": "default",
  "description": "Default capabilities for Mewsic",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "$AUDIO/**"
        },
        {
          "path": "$MUSIC/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "**"
        }
      ]
    },
    "shell:default",
    "notification:default",
    "updater:default"
  ]
}