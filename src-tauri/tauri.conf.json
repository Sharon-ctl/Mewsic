{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Mewsic",
  "version": "../package.json",
  "identifier": "dev.xeoniii.mewsic",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "category": "Music",
    "targets": [
      "msi",
      "nsis",
      "deb",
      "rpm",
      "dmg",
      "app"
    ],
    "createUpdaterArtifacts": true,
    "publisher": "xeoniii",
    "copyright": "Copyright © 2026 xeoniii",
    "shortDescription": "Mewsic - Premium Music Player",
    "longDescription": "A premium, open-source music player licensed under GPL v3.0, designed for audiophiles with a focus on speed and aesthetics.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-common"
        ]
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libappindicator-gtk3",
          "librsvg2"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "fileAssociations": [
      {
        "ext": ["mewsic"],
        "name": "Mewsic Plugin",
        "description": "Mewsic plugin package",
        "mimeType": "application/x-mewsic-plugin",
        "role": "Editor"
      },
      {
        "ext": ["mp3"],
        "name": "MP3 Audio",
        "description": "MPEG Audio Layer III",
        "mimeType": "audio/mpeg",
        "role": "Viewer"
      },
      {
        "ext": ["flac"],
        "name": "FLAC Audio",
        "description": "Free Lossless Audio Codec",
        "mimeType": "audio/flac",
        "role": "Viewer"
      },
      {
        "ext": ["wav"],
        "name": "WAV Audio",
        "description": "Waveform Audio",
        "mimeType": "audio/wav",
        "role": "Viewer"
      },
      {
        "ext": ["ogg"],
        "name": "OGG Audio",
        "description": "Ogg Vorbis Audio",
        "mimeType": "audio/ogg",
        "role": "Viewer"
      },
      {
        "ext": ["m4a"],
        "name": "M4A Audio",
        "description": "MPEG-4 Audio",
        "mimeType": "audio/mp4",
        "role": "Viewer"
      },
      {
        "ext": ["aac"],
        "name": "AAC Audio",
        "description": "Advanced Audio Coding",
        "mimeType": "audio/aac",
        "role": "Viewer"
      },
      {
        "ext": ["opus"],
        "name": "Opus Audio",
        "description": "Opus Audio",
        "mimeType": "audio/opus",
        "role": "Viewer"
      },
      {
        "ext": ["aiff", "aif"],
        "name": "AIFF Audio",
        "description": "Audio Interchange File Format",
        "mimeType": "audio/aiff",
        "role": "Viewer"
      },
      {
        "ext": ["wma"],
        "name": "WMA Audio",
        "description": "Windows Media Audio",
        "mimeType": "audio/x-ms-wma",
        "role": "Viewer"
      }
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Mewsic",
        "width": 1280,
        "height": 800,
        "minWidth": 360,
        "minHeight": 500,
        "decorations": false,
        "transparent": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; connect-src 'self' ws://127.0.0.1:3012 ws://localhost:3012 ws://127.0.0.1:3678 http://* https://*; media-src 'self' asset: http://asset.localhost https://asset.localhost http://127.0.0.1:1422 http://localhost:1422 http://* https://*; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost http://127.0.0.1:1422 http://localhost:1422 https://*.mzstatic.com https://*.saavncdn.com https://*.ytimg.com https://*.googleusercontent.com http://* https://*",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/xeoniii/Mewsic/main/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzMTQ3Qzg3QzhDQzc2NEYKUldSUGRzekloM3dVczA5ZE4xd0J2N0FJMWlIRjhaZ0ppb1F5czU3VForU092REVzR0dDbkMzNVIK"
    }
  }
}